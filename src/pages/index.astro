<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Borion AI — AI That Ships</title>
<meta name="description" content="Borion AI deploys production AI agents in 60–90 days with payment tied to delivery. 20+ enterprise projects delivered.">
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
<style>
  /* Roobert isn't free; use a clean geometric stack as a stand-in for the headings.
     Inter Tight + system geometric is the closest visual match for Roobert Medium. */
  :root{
    --navy: #141e42;
    --navy-deep: #0b1230;
    --navy-mid: #0d3084;
    --blue: #195add;
    --purple: #6f5dd2;
    --lavender: #d2ccf1;
    --white: #ffffff;
    --line: rgba(210, 204, 241, 0.12);
    --line-strong: rgba(210, 204, 241, 0.22);
    --muted: rgba(210, 204, 241, 0.72);
    --dim: rgba(210, 204, 241, 0.55);
  }

  *{ box-sizing: border-box; }
  html, body{ margin: 0; padding: 0; }
  body{
    background: var(--navy);
    color: var(--white);
    font-family: 'Manrope', ui-sans-serif, system-ui, -apple-system, sans-serif;
    font-weight: 400;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  .head{
    font-family: 'Inter Tight', 'Manrope', ui-sans-serif, system-ui, sans-serif;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  /* ---------- LAYOUT ---------- */
  .wrap{
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ---------- BACKGROUND TEXTURE ---------- */
  .bg-grid{
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(210,204,241,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(210,204,241,0.04) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 90% 60% at 50% 30%, black 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 90% 60% at 50% 30%, black 30%, transparent 75%);
    z-index: 0;
  }

  /* ---------- NAV ---------- */
  .nav{
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    background: rgba(20, 30, 66, 0.72);
    border-bottom: 1px solid var(--line);
  }
  .nav-inner{
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 76px;
  }
  .logo{
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    line-height: 0;
  }
  .logo img{
    height: 36px;
    width: auto;
    display: block;
  }
  .foot-inner .logo img{ height: 34px; }
  .nav-links{
    display: flex;
    align-items: center;
    gap: 36px;
  }
  .nav-links a{
    color: var(--muted);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: color 0.2s ease;
  }
  .nav-links a:hover{ color: var(--white); }

  .btn{
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 14px;
    letter-spacing: -0.01em;
    padding: 11px 20px;
    border-radius: 10px;
    border: 1px solid transparent;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
    white-space: nowrap;
  }
  .btn-primary{
    background: var(--blue);
    color: white;
    box-shadow: 0 1px 0 rgba(255,255,255,0.18) inset, 0 8px 24px -8px rgba(25, 90, 221, 0.6);
  }
  .btn-primary:hover{
    background: #2a6bee;
    transform: translateY(-1px);
    box-shadow: 0 1px 0 rgba(255,255,255,0.22) inset, 0 14px 28px -10px rgba(25, 90, 221, 0.75);
  }
  .btn-ghost{
    background: rgba(210, 204, 241, 0.06);
    color: white;
    border-color: var(--line-strong);
  }
  .btn-ghost:hover{
    background: rgba(210, 204, 241, 0.12);
    border-color: rgba(210, 204, 241, 0.32);
  }
  .btn-lg{ padding: 15px 26px; font-size: 15px; border-radius: 12px; }

  /* ---------- HERO ---------- */
  .hero{
    position: relative;
    padding: 96px 0 120px;
    overflow: hidden;
    z-index: 1;
    min-height: 80vh;
    display: flex;
    align-items: center;
  }
  #heroCanvas{
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero::before{
    content: "";
    position: absolute;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 1100px;
    height: 700px;
    background: radial-gradient(ellipse at center, rgba(25, 90, 221, 0.35) 0%, rgba(13, 48, 132, 0.1) 50%, transparent 70%);
    filter: blur(40px);
    pointer-events: none;
    z-index: -1;
  }
  .hero::after{
    content: "";
    position: absolute;
    bottom: -100px;
    right: -100px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(111, 93, 210, 0.25) 0%, transparent 60%);
    filter: blur(60px);
    pointer-events: none;
    z-index: -1;
  }
  .hero-content{ text-align: center; max-width: 850px; margin: 0 auto; }
  h1.hero-title{
    font-size: clamp(48px, 8vw, 90px);
    margin: 0 0 24px;
    color: white;
  }
  h1.hero-title em{
    font-style: normal;
    background: linear-gradient(120deg, #ffffff 0%, #d2ccf1 50%, #6f5dd2 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    display: block;
  }
  .hero-sub{
    font-size: clamp(18px, 2.5vw, 22px);
    line-height: 1.55;
    color: var(--muted);
    max-width: 600px;
    margin: 0 auto 40px;
    font-weight: 400;
  }
  .hero-ctas{
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  /* ---------- LOGO BAR ---------- */
  .logo-bar{
    padding: 2.5rem 2rem;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: var(--navy-deep);
  }
  .logo-bar-label{
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--dim);
    text-align: center;
    margin-bottom: 1.5rem;
    font-family: 'Inter Tight', sans-serif;
  }
  .logo-track{
    display: flex;
    gap: 3rem;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
  }
  .logo-item{
    font-family: 'Inter Tight', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: rgba(255,255,255,0.35);
    white-space: nowrap;
    transition: color 0.3s;
  }
  .logo-item:hover{ color: var(--blue); }
  .logo-item.nda{ font-style: italic; font-weight: 400; font-size: 13px; }

  /* ---------- PROOF BAR ---------- */
  .proof-bar{
    padding: 4rem 2rem;
    background: var(--navy);
  }
  .proof-grid{
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }
  .proof-item .number{
    font-family: 'Inter Tight', sans-serif;
    font-size: 3rem;
    font-weight: 800;
    color: var(--blue);
    line-height: 1;
  }
  .proof-item .label{
    font-size: 12px;
    color: var(--dim);
    margin-top: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 500;
  }

  /* ---------- SECTIONS ---------- */
  section{ position: relative; z-index: 1; padding: 120px 0; }
  .section{
    padding: 120px 0;
  }
  .section-header{
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
    margin-bottom: 64px;
  }
  .section-eyebrow{
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--blue);
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-eyebrow::before{
    content: "";
    width: 24px; height: 1px;
    background: var(--blue);
  }
  h2.section-title{
    font-size: clamp(36px, 4.4vw, 54px);
    margin: 0;
    max-width: 640px;
    color: white;
  }
  .section-lede{
    font-size: 16.5px;
    color: var(--muted);
    max-width: 650px;
    line-height: 1.55;
    margin: 0;
    padding-bottom: 8px;
  }

  /* ---------- PROBLEM SECTION ---------- */
  .problem-section{
    background: linear-gradient(180deg, var(--navy-deep) 0%, var(--navy) 100%);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .stats-row{
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .stat-block{
    background: var(--navy);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    transition: all 0.3s;
  }
  .stat-block:hover{
    border-color: var(--blue);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(25, 90, 221, 0.15);
  }
  .stat-block .val{
    font-family: 'Inter Tight', sans-serif;
    font-size: 2.75rem;
    font-weight: 800;
    color: white;
    line-height: 1;
  }
  .stat-block .val span{ color: var(--blue); }
  .stat-block .desc{
    font-size: 14px;
    color: var(--muted);
    margin-top: 0.5rem;
  }

  /* ---------- SERVICES ---------- */
  .services-grid{
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .service{
    position: relative;
    padding: 36px 32px 32px;
    border-radius: 20px;
    background: linear-gradient(180deg, rgba(210, 204, 241, 0.045), rgba(210, 204, 241, 0.015));
    border: 1px solid var(--line);
    overflow: hidden;
    transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease;
    cursor: default;
  }
  .service::before{
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(210,204,241,0.4), transparent);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .service:hover{
    transform: translateY(-4px);
    border-color: var(--line-strong);
    background: linear-gradient(180deg, rgba(25, 90, 221, 0.08), rgba(210, 204, 241, 0.02));
  }
  .service:hover::before{ opacity: 1; }

  .svc-title{
    font-size: 22px;
    margin: 0 0 12px;
    color: white;
  }
  .svc-desc{
    font-size: 15px;
    color: var(--muted);
    line-height: 1.55;
    margin: 0 0 20px;
  }
  .price-tag{
    display: inline-block;
    margin-top: 1rem;
    font-family: 'Inter Tight', sans-serif;
    font-size: 13px;
    color: var(--blue);
    padding: 6px 12px;
    border: 1px solid rgba(25, 90, 221, 0.3);
    border-radius: 8px;
  }

  /* ---------- PRICING ---------- */
  .pricing-grid{
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  .pricing-card{
    background: linear-gradient(180deg, rgba(210, 204, 241, 0.045), rgba(210, 204, 241, 0.015));
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 2rem 2rem 2rem;
    transition: all 0.3s;
  }
  .pricing-card:hover{
    border-color: var(--blue);
    transform: translateY(-4px);
    box-shadow: 0 16px 50px rgba(0,0,0,0.3);
  }
  .pricing-card.featured{
    border-color: var(--blue);
  }
  .pricing-tier{
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--blue);
    margin-bottom: 0.5rem;
  }
  .pricing-title{
    font-family: 'Inter Tight', sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: white;
    margin-bottom: 0.75rem;
  }
  .pricing-amount{
    font-family: 'Inter Tight', sans-serif;
    font-size: 32px;
    font-weight: 700;
    color: white;
    margin: 0.5rem 0;
  }
  .pricing-amount .period{
    font-size: 16px;
    font-weight: 400;
    color: var(--dim);
  }
  .pricing-desc{
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
  }

  /* ---------- TIMELINE ---------- */
  .timeline-section{
    background: linear-gradient(180deg, var(--navy-deep) 0%, var(--navy) 100%);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .timeline{
    display: flex;
    gap: 0;
    margin: 3rem 0;
    position: relative;
  }
  .timeline::before{
    content: '';
    position: absolute;
    top: 32px;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--blue), var(--purple), var(--blue));
  }
  .tl-step{
    flex: 1;
    text-align: center;
    position: relative;
    padding-top: 4.5rem;
  }
  .tl-step::before{
    content: attr(data-num);
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 64px;
    height: 64px;
    background: var(--navy);
    color: var(--blue);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter Tight', sans-serif;
    font-weight: 700;
    font-size: 14px;
    border: 2px solid var(--blue);
    z-index: 1;
    box-shadow: 0 0 20px rgba(25, 90, 221, 0.3);
  }
  .tl-step h4{
    font-family: 'Inter Tight', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: white;
    margin-bottom: 0.25rem;
  }
  .tl-step p{
    font-size: 13px;
    color: var(--dim);
  }

  /* ---------- CASE STUDIES ---------- */
  .filter-row{
    display: flex;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }
  .fbtn{
    padding: 10px 20px;
    border: 1px solid var(--line);
    border-radius: 24px;
    background: transparent;
    font-family: 'Inter Tight', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.3s;
  }
  .fbtn.active, .fbtn:hover{
    background: var(--blue);
    color: white;
    border-color: var(--blue);
    box-shadow: 0 4px 16px rgba(25, 90, 221, 0.4);
  }
  .cases-grid{
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .cc{
    background: var(--navy-deep);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 2rem 1.75rem;
    overflow: hidden;
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .cc:hover{
    border-color: var(--blue);
    transform: translateY(-8px);
    box-shadow: 0 24px 48px rgba(25, 90, 221, 0.25), 0 0 0 1px var(--blue);
  }
  .cc.hidden{ display: none; }
  .cc-metric{
    font-family: 'Inter Tight', sans-serif;
    font-size: 26px;
    font-weight: 800;
    background: linear-gradient(135deg, var(--blue) 0%, var(--purple) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }
  .cc-head .client{
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--dim);
    margin-bottom: 0.5rem;
  }
  .cc-head h3{
    font-family: 'Inter Tight', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: white;
    line-height: 1.3;
    margin: 0.5rem 0 0.75rem;
  }
  .cc-body p{
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
    font-weight: 400;
    margin: 0;
  }
  .cc-tags{
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: auto;
    padding-top: 0.5rem;
  }
  .cc-tags span{
    font-size: 11px;
    background: rgba(25, 90, 221, 0.15);
    color: var(--blue);
    padding: 6px 12px;
    border-radius: 12px;
    font-weight: 600;
    border: 1px solid rgba(25, 90, 221, 0.25);
  }

  /* ---------- MODAL ---------- */
  .modal-bg{
    position: fixed;
    inset: 0;
    background: rgba(6, 16, 26, 0.92);
    z-index: 2000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .modal-bg.active{ display: flex; }
  .mdl{
    background: var(--navy-deep);
    border: 1px solid var(--line);
    border-radius: 20px;
    max-width: 800px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    animation: mdlIn 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.5);
  }
  @keyframes mdlIn{
    from{ opacity: 0; transform: scale(0.95) translateY(20px); }
    to{ opacity: 1; transform: scale(1) translateY(0); }
  }
  .mdl-close{
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--line);
    background: var(--navy);
    cursor: pointer;
    font-size: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    transition: all 0.2s;
    z-index: 1;
  }
  .mdl-close:hover{
    background: var(--blue);
    color: white;
    border-color: var(--blue);
    transform: rotate(90deg);
  }
  .mdl-top{
    padding: 3rem 3rem 2rem;
    border-bottom: 1px solid var(--line);
  }
  .mdl-top .metric{
    font-family: 'Inter Tight', sans-serif;
    font-size: 32px;
    font-weight: 800;
    color: var(--blue);
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  .mdl-top h2{
    font-family: 'Inter Tight', sans-serif;
    font-size: 26px;
    font-weight: 700;
    color: white;
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }
  .mdl-top .ind{
    font-size: 13px;
    color: var(--dim);
    font-weight: 500;
  }
  .mdl-bod{
    padding: 2.5rem 3rem 3rem;
  }
  .mdl-bod h4{
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--blue);
    margin: 2rem 0 0.75rem;
    font-family: 'Inter Tight', sans-serif;
  }
  .mdl-bod h4:first-child{ margin-top: 0; }
  .mdl-bod p{
    font-size: 15px;
    color: var(--lavender);
    line-height: 1.7;
    font-weight: 400;
    margin: 0;
  }
  .mdl-bod ul{
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
  }
  .mdl-bod li{
    padding: 0.5rem 0 0.5rem 1.5rem;
    font-size: 15px;
    color: var(--lavender);
    position: relative;
    font-weight: 400;
    line-height: 1.6;
  }
  .mdl-bod li::before{
    content: '→';
    position: absolute;
    left: 0;
    color: var(--blue);
    font-weight: 700;
    font-size: 16px;
  }
  .mdl-tech{
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 13px;
    color: var(--muted);
    background: var(--navy);
    padding: 1rem 1.25rem;
    border-radius: 10px;
    margin-top: 0.5rem;
    border: 1px solid var(--line);
    line-height: 1.6;
  }

  /* ---------- TEAM ---------- */
  .team-section{
    background: linear-gradient(180deg, var(--navy-deep) 0%, var(--navy) 100%);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .team-grid{
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-top: 2rem;
  }
  .team-card{
    background: var(--navy);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
  }
  .team-card::before{
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--blue), var(--purple));
  }
  .team-card h3{
    font-family: 'Inter Tight', sans-serif;
    font-size: 24px;
    font-weight: 700;
    color: white;
  }
  .team-card .role{
    font-size: 13px;
    color: var(--blue);
    font-weight: 600;
