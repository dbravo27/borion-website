function resize(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight}
window.addEventListener('resize',resize);resize();
class P{constructor(){this.x=Math.random()*W;this.y=Math.random()*H;this.vx=(Math.random()-.5)*.4;this.vy=(Math.random()-.5)*.4;this.r=Math.random()*1.5+.5;this.hue=Math.random()>.5?210:260}
update(){this.x+=this.vx;this.y+=this.vy;if(this.x<0||this.x>W)this.vx*=-1;if(this.y<0||this.y>H)this.vy*=-1}
draw(){ctx.beginPath();ctx.arc(this.x,this.y,this.r,0,Math.PI*2);ctx.fillStyle=`hsla(${this.hue},80%,60%,.5)`;ctx.fill()}}
for(let i=0;i<80;i++)particles.push(new P);
function animate(){ctx.clearRect(0,0,W,H);particles.forEach(p=>{p.update();p.draw()});
for(let i=0;i<particles.length;i++)for(let j=i+1;j<particles.length;j++){
const dx=particles[i].x-particles[j].x,dy=particles[i].y-particles[j].y,d=Math.sqrt(dx*dx+dy*dy);
if(d<150){ctx.beginPath();ctx.moveTo(particles[i].x,particles[i].y);ctx.lineTo(particles[j].x,particles[j].y);
ctx.strokeStyle=`rgba(25,90,221,${(.15*(1-d/150)).toFixed(3)})`;ctx.lineWidth=.5;ctx.stroke()}}
requestAnimationFrame(animate)}animate();

