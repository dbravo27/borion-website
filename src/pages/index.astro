---
import CaseStudies from '../components/CaseStudies.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Borion AI — AI That Ships</title>
<meta name="description" content="Borion AI deploys production AI agents in 60–90 days with payment tied to delivery. 20+ enterprise projects delivered.">
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
<style>
  /* Roobert isn't free; use a clean geometric stack as a stand-in for the headings.
     Inter Tight + system geometric is the closest visual match for Roobert Medium. */
  :root{
    --navy: #141e42;
    --navy-deep: #0b1230;
    --navy-mid: #0d3084;
    --blue: #195add;
    --purple: #6f5dd2;
    --lavender: #d2ccf1;
    --white: #ffffff;
    --line: rgba(210, 204, 241, 0.12);
    --line-strong: rgba(210, 204, 241, 0.22);
    --muted: rgba(210, 204, 241, 0.72);
    --dim: rgba(210, 204, 241, 0.55);
  }

  *{ box-sizing: border-box; }
  html, body{ margin: 0; padding: 0; }
  body{
    background: var(--navy);
    color: var(--white);
    font-family: 'Manrope', ui-sans-serif, system-ui, -apple-system, sans-serif;
    font-weight: 400;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  .head{
    font-family: 'Inter Tight', 'Manrope', ui-sans-serif, system-ui, sans-serif;
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.05;
  }

  /* ---------- LAYOUT ---------- */
  .wrap{
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ---------- BACKGROUND TEXTURE ---------- */
  .bg-grid{
    position: fixed;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(210,204,241,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(210,204,241,0.04) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse 90% 60% at 50% 30%, black 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 90% 60% at 50% 30%, black 30%, transparent 75%);
    z-index: 0;
  }

  /* ---------- NAV ---------- */
  .nav{
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    background: rgba(20, 30, 66, 0.72);
    border-bottom: 1px solid var(--line);
  }
  .nav-inner{
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 76px;
  }
  .logo{
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    line-height: 0;
  }
  .logo img{
    height: 36px;
    width: auto;
    display: block;
  }
  .foot-inner .logo img{ height: 34px; }
  .nav-links{
    display: flex;
    align-items: center;
    gap: 36px;
  }
  .nav-links a{
    color: var(--muted);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: color 0.2s ease;
  }
  .nav-links a:hover{ color: var(--white); }

  /* Hamburger Menu */
  .hamburger{
    display: none;
    flex-direction: column;
    gap: 5px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 8px;
    z-index: 60;
  }
  .hamburger span{
    display: block;
    width: 24px;
    height: 2px;
    background: white;
    transition: all 0.3s ease;
    border-radius: 2px;
  }
  .hamburger.active span:nth-child(1){
    transform: rotate(45deg) translate(7px, 7px);
  }
  .hamburger.active span:nth-child(2){
    opacity: 0;
  }
  .hamburger.active span:nth-child(3){
    transform: rotate(-45deg) translate(7px, -7px);
  }

  /* Mobile Menu Overlay */
  .mobile-menu{
    position: fixed;
    inset: 0;
    background: rgba(20, 30, 66, 0.98);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    z-index: 55;
    display: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .mobile-menu.active{
    display: flex;
    opacity: 1;
  }
  .mobile-menu-close{
    position: absolute;
    top: 20px;
    right: 20px;
    background: transparent;
    border: none;
    color: white;
    font-size: 2rem;
    cursor: pointer;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease;
  }
  .mobile-menu-close:hover{
    color: var(--blue);
  }
  .mobile-menu-nav{
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    gap: 0.5rem;
  }
  .mobile-menu-link{
    color: white;
    text-decoration: none;
    font-size: 1.5rem;
    font-weight: 500;
    padding: 1rem;
    transition: color 0.2s ease;
    font-family: 'Inter Tight', sans-serif;
  }
  .mobile-menu-link:hover{
    color: var(--blue);
  }
  .mobile-menu-cta{
    background: var(--blue);
    padding: 1rem 2.5rem;
    border-radius: 12px;
    margin-top: 1rem;
    font-weight: 600;
  }
  .mobile-menu-cta:hover{
    background: var(--purple);
    color: white;
  }

  @media (max-width: 768px){
    .nav-links{
      display: none;
    }
    .hamburger{
      display: flex;
    }
  }

  .btn{
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: 'Manrope', sans-serif;
    font-weight: 600;
    font-size: 14px;
    letter-spacing: -0.01em;
    padding: 11px 20px;
    border-radius: 10px;
    border: 1px solid transparent;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
    white-space: nowrap;
  }
  .btn-primary{
    background: var(--blue);
    color: white;
    box-shadow: 0 1px 0 rgba(255,255,255,0.18) inset, 0 8px 24px -8px rgba(25, 90, 221, 0.6);
  }
  .btn-primary:hover{
    background: #2a6bee;
    transform: translateY(-1px);
    box-shadow: 0 1px 0 rgba(255,255,255,0.22) inset, 0 14px 28px -10px rgba(25, 90, 221, 0.75);
  }
  .btn-ghost{
    background: transparent;
    color: white;
    border-color: white;
  }
  .btn-ghost:hover{
    background: transparent;
    color: var(--blue);
    border-color: var(--blue);
  }
  .btn-lg{ padding: 15px 26px; font-size: 15px; border-radius: 12px; }

  /* ---------- HERO ---------- */
  .hero{
    position: relative;
    padding: 96px 0 120px;
    overflow: hidden;
    z-index: 1;
    min-height: 80vh;
    display: flex;
    align-items: center;
  }
  #heroCanvas{
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero::before{
    content: "";
    position: absolute;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 1100px;
    height: 700px;
    background: radial-gradient(ellipse at center, rgba(25, 90, 221, 0.35) 0%, rgba(13, 48, 132, 0.1) 50%, transparent 70%);
    filter: blur(40px);
    pointer-events: none;
    z-index: -1;
  }
  .hero::after{
    content: "";
    position: absolute;
    bottom: -100px;
    right: -100px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(111, 93, 210, 0.25) 0%, transparent 60%);
    filter: blur(60px);
    pointer-events: none;
    z-index: -1;
  }
  .hero-content{ text-align: center; max-width: 850px; margin: 0 auto; }
  .hero-badge{
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: 999px;
    border: 1px solid rgba(25, 90, 221, 0.3);
    background: rgba(25, 90, 221, 0.1);
    font-size: 13px;
    font-weight: 500;
    color: var(--lavender);
    margin-bottom: 24px;
  }
  .pulse-dot{
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #10b981;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse{
    0%, 100%{ opacity: 1; transform: scale(1); }
    50%{ opacity: 0.6; transform: scale(0.9); }
  }
  h1.hero-title{
    font-size: clamp(48px, 8vw, 90px);
    margin: 0 0 24px;
    color: white;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .rotating-container{
    position: relative;
    height: 1.2em;
    width: 100%;
    text-align: center;
  }
  h1.hero-title .rotating-word{
    position: absolute;
    left: 50%;
    top: 0;
    transform: translateX(-50%);
    font-style: normal;
    background: linear-gradient(120deg, #195add 0%, #6f5dd2 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    white-space: nowrap;
    transition: opacity 0.5s ease;
  }
  h1.hero-title .rotating-word.fade-out{
    opacity: 0;
  }
  .hero-sub{
    font-size: clamp(18px, 2.5vw, 22px);
    line-height: 1.55;
    color: var(--muted);
    max-width: 600px;
    margin: 0 auto 40px;
    font-weight: 400;
  }
  .hero-ctas{
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }
  .hero-trust{
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.4);
    text-align: center;
    font-weight: 400;
  }

  /* ---------- LOGO BAR ---------- */
  .logo-bar{
    padding: 2.5rem 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    background: var(--navy-deep);
    overflow: hidden;
  }
  .logo-bar-label{
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--dim);
    text-align: center;
    margin-bottom: 1.5rem;
    font-family: 'Inter Tight', sans-serif;
  }
  .marquee{
    position: relative;
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }
  .marquee-content{
    display: flex;
    gap: 4rem;
    animation: marquee 30s linear infinite;
    width: fit-content;
  }
  .marquee:hover .marquee-content{
    animation-play-state: paused;
  }
  @keyframes marquee{
    0%{ transform: translateX(0); }
    100%{ transform: translateX(-50%); }
  }
  .logo-item{
    font-family: 'Inter Tight', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: rgba(255,255,255,0.35);
    white-space: nowrap;
    transition: color 0.3s;
  }
  .logo-item:hover{ color: var(--blue); }
  .logo-item.nda{ font-style: italic; font-weight: 400; font-size: 13px; }

  /* ---------- PROOF BAR ---------- */
  .proof-bar{
    padding: 4rem 2rem;
    background: var(--navy-mid);
  }
  .proof-grid{
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2rem;
    text-align: center;
  }
  .proof-item .number{
    font-family: 'Inter Tight', sans-serif;
    font-size: 3rem;
    font-weight: 800;
    color: var(--blue);
    line-height: 1;
  }
  .proof-item .label{
    font-size: 12px;
    color: var(--dim);
    margin-top: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 500;
  }

  /* ---------- SECTIONS ---------- */
  section{ position: relative; z-index: 1; padding: 120px 0; }
  .section{
    padding: 120px 0;
  }
  .section-header{
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
    margin-bottom: 64px;
  }
  .section-eyebrow{
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--blue);
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-eyebrow::before{
    content: "";
    width: 24px; height: 1px;
    background: var(--blue);
  }
  h2.section-title{
    font-size: clamp(36px, 4.4vw, 54px);
    margin: 0;
    max-width: 640px;
    color: white;
  }
  .section-lede{
    font-size: 16.5px;
    color: var(--muted);
    max-width: 650px;
    line-height: 1.55;
    margin: 0;
    padding-bottom: 8px;
  }

  /* ---------- PROBLEM SECTION ---------- */
  .problem-section{
    background: linear-gradient(180deg, var(--navy-deep) 0%, var(--navy) 100%);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .stats-row{
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .stat-block{
    background: var(--navy);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    transition: all 0.3s;
  }
  .stat-block:hover{
    border-color: var(--blue);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(25, 90, 221, 0.15);
  }
  .stat-block .val{
    font-family: 'Inter Tight', sans-serif;
    font-size: 2.75rem;
    font-weight: 800;
    background: linear-gradient(135deg, var(--blue) 0%, var(--purple) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    line-height: 1;
  }
  .stat-block .val span{
    background: linear-gradient(135deg, var(--blue) 0%, var(--purple) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .stat-block .desc{
    font-size: 14px;
    color: var(--muted);
    margin-top: 0.5rem;
  }

  /* ---------- WHY US ---------- */
  .why-us-section{
    padding: 100px 0;
    background: #0a1628;
  }
  .why-us-subtext{
    text-align: center;
    max-width: 800px;
    margin: 0 auto 4rem;
    font-size: 0.95rem;
    color: var(--dim);
    font-weight: 300;
  }
  .accordion-list{
    max-width: 1200px;
    margin: 3rem auto 0;
  }
  .accordion-item{
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .accordion-item.active{
    border-left: 3px solid #195add;
  }
  .accordion-header{
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    padding: 2rem;
    transition: all 0.3s ease;
  }
  .accordion-header:hover{
    background: rgba(255, 255, 255, 0.02);
  }
  .accordion-left{
    flex: 0 0 40%;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .accordion-right{
    flex: 1;
    overflow: hidden;
  }
  .pillar-number{
    font-family: 'Inter Tight', sans-serif;
    font-size: 4rem;
    font-weight: 800;
    background: linear-gradient(135deg, #195add 0%, #6f5dd2 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    opacity: 0.2;
    line-height: 1;
    margin-bottom: 0.5rem;
    transition: opacity 0.3s ease;
  }
  .accordion-item.active .pillar-number{
    opacity: 1;
  }
  .pillar-title{
    font-family: 'Inter Tight', sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: white;
    margin: 0 0 0.5rem;
  }
  .pillar-teaser{
    font-size: 0.9rem;
    color: #999;
    line-height: 1.5;
    margin: 0;
  }
  .accordion-expand-icon{
    font-size: 1.5rem;
    color: #195add;
    transition: transform 0.3s ease;
    margin-left: auto;
    flex-shrink: 0;
  }
  .accordion-item.active .accordion-expand-icon{
    transform: rotate(45deg);
  }
  .accordion-content{
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }
  .accordion-item.active .accordion-content{
    max-height: 500px;
  }
  .pillar-full-text{
    font-size: 0.9rem;
    color: #999;
    line-height: 1.8;
    margin: 0;
    padding: 0 2rem 2rem 2rem;
  }
  @media (max-width: 980px){
    .accordion-header{
      flex-direction: column;
      gap: 1rem;
    }
    .accordion-left{
      flex: 1;
    }
    .pillar-number{
      font-size: 3rem;
    }
  }

  /* ---------- SERVICES ---------- */
  .services-grid{
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .service{
    position: relative;
    padding: 36px 32px 32px;
    border-radius: 20px;
    background: var(--navy);
    border: 1px solid var(--line);
    overflow: hidden;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    cursor: default;
  }
  .service::before{
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--blue), var(--purple));
    opacity: 1;
  }
  .service:hover{
    transform: translateY(-6px);
    border-color: var(--line-strong);
    box-shadow: 0 20px 40px -20px rgba(25, 90, 221, 0.4);
  }
  .service-icon{
    width: 80px;
    height: 80px;
    margin-bottom: 20px;
  }
  .service-icon svg{
    width: 100%;
    height: 100%;
  }
  .svc-title{
    font-size: 22px;
    margin: 0 0 6px;
    color: white;
  }
  .svc-subtitle{
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--blue);
    margin-bottom: 16px;
  }
  .svc-desc{
    font-size: 15px;
    color: var(--muted);
    line-height: 1.55;
    margin: 0 0 20px;
  }
  .price-tag{
    display: inline-block;
    margin-top: 1rem;
    font-family: 'Inter Tight', sans-serif;
    font-size: 13px;
    color: var(--blue);
    padding: 6px 12px;
    border: 1px solid rgba(25, 90, 221, 0.3);
    border-radius: 8px;
  }

  /* ---------- PRICING ---------- */
  .pricing-grid{
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  .pricing-card{
    background: linear-gradient(180deg, rgba(210, 204, 241, 0.045), rgba(210, 204, 241, 0.015));
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 2rem 2rem 2rem;
    transition: all 0.3s;
  }
  .pricing-card:hover{
    border-color: var(--blue);
    transform: translateY(-4px);
    box-shadow: 0 16px 50px rgba(0,0,0,0.3);
  }
  .pricing-card.featured{
    border-color: var(--blue);
  }
  .pricing-tier{
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--blue);
    margin-bottom: 0.5rem;
  }
  .pricing-title{
    font-family: 'Inter Tight', sans-serif;
    font-size: 20px;
    font-weight: 600;
    color: white;
    margin-bottom: 0.75rem;
  }
  .pricing-amount{
    font-family: 'Inter Tight', sans-serif;
    font-size: 32px;
    font-weight: 700;
    color: white;
    margin: 0.5rem 0;
  }
  .pricing-amount .period{
    font-size: 16px;
    font-weight: 400;
    color: var(--dim);
  }
  .pricing-desc{
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
  }

  /* ---------- TIMELINE ---------- */
  .timeline-section{
    background: linear-gradient(180deg, var(--navy-deep) 0%, var(--navy) 100%);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .timeline{
    display: flex;
    gap: 0;
    margin: 3rem 0;
    position: relative;
  }
  .timeline::before{
    content: '';
    position: absolute;
    top: 32px;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--blue), var(--purple), var(--blue));
  }
  .tl-step{
    flex: 1;
    text-align: center;
    position: relative;
    padding-top: 4.5rem;
  }
  .tl-step::before{
    content: attr(data-num);
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 64px;
    height: 64px;
    background: var(--navy);
    color: var(--blue);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter Tight', sans-serif;
    font-weight: 700;
    font-size: 14px;
    border: 2px solid var(--blue);
    z-index: 1;
    box-shadow: 0 0 20px rgba(25, 90, 221, 0.3);
  }
  .tl-step h4{
    font-family: 'Inter Tight', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: white;
    margin-bottom: 0.25rem;
  }
  .tl-step p{
    font-size: 13px;
    color: var(--dim);
  }

