---
// CaseStudies.astro
// Drop into src/components/ and use as <CaseStudies /> in any Astro page.
//
// Brand tokens used: --blue (#195add), --purple (#6f5dd2), --navy (#141e42),
// --lavender (#d2ccf1). These are read with fallbacks, so the section works
// standalone OR picks up your global tokens if you define them.
//
// The case-study data is inlined below in TypeScript. Edit the array to add /
// remove projects. The "cat" field controls the filter bucket (agentic | analytics
// | enablement); add new categories by also editing the filter pill markup.
//
// Fonts assumed: Manrope (body) + Inter Tight (headings) loaded globally by your
// site. If you don't load them, the snippet falls back to system sans-serif.

interface CaseStudy {
  cat: 'agentic' | 'analytics' | 'enablement';
  metric: string;
  client: string;
  title: string;
  challenge: string;
  tags: string[];
}

const cases: CaseStudy[] = [
  {
    cat: 'agentic',
    metric: '11M+ users served',
    client: 'EdTech',
    title: 'Autonomous Content Curation Pipeline',
    challenge: 'Replaced a 12-person manual curation team with an LLM-driven agent stack handling personalization, moderation, and re-ranking at platform scale.',
    tags: ['Agentic AI', 'LLM Orchestration', 'RAG'],
  },
  {
    cat: 'agentic',
    metric: '70% prep time reduction',
    client: 'Healthcare',
    title: 'Pre-Visit Clinical Summarization Agent',
    challenge: 'Multi-source EHR ingestion + structured summarization agent. HIPAA-compliant, deployed inside the EHR, sub-3s latency on 8-page chart synthesis.',
    tags: ['Agentic AI', 'Clinical NLP', 'HIPAA'],
  },
  {
    cat: 'agentic',
    metric: '6–8wk earlier escalation flag',
    client: 'Healthcare',
    title: 'Predictive Risk Stratification Engine',
    challenge: 'Real-time scoring pipeline over longitudinal patient data. Streaming features, drift monitoring, and clinician-facing explanations on every prediction.',
    tags: ['ML', 'Streaming', 'Explainable AI'],
  },
  {
    cat: 'agentic',
    metric: '3x guideline adherence',
    client: 'Healthcare',
    title: 'Treatment Decision Support System',
    challenge: 'Retrieval-grounded recommendations with citation traceback. Every output links to the underlying clinical evidence — no black-box predictions in the loop.',
    tags: ['RAG', 'Explainable AI', 'Evaluation Harness'],
  },
  {
    cat: 'agentic',
    metric: '25% pipeline conversion lift',
    client: 'Technology',
    title: 'Real-Time Financial Intelligence Agent',
    challenge: 'Multi-tool agent over SEC filings, transcripts, and live market data. Sub-2s response, citation-grounded, embedded directly in the AE workflow.',
    tags: ['Agentic AI', 'Multi-Tool RAG', 'Live Data'],
  },
  {
    cat: 'agentic',
    metric: '40% efficiency, 20% revenue',
    client: 'Transportation',
    title: 'Dynamic Routing Agent',
    challenge: 'Real-time reoptimization over a fleet graph with traffic, demand, and SLA constraints. Decisions in <500ms; 12M+ events/day through the optimization loop.',
    tags: ['AI Agents', 'Optimization', 'Real-Time'],
  },
  {
    cat: 'analytics',
    metric: '8 isolated revenue drivers',
    client: 'CPG',
    title: 'Marketing Mix Modeling Platform',
    challenge: 'Bayesian MMM with hierarchical priors across brands, regions, and channels. Replaces vendor MMM that took 6 months per refresh — now weekly.',
    tags: ['Bayesian Modeling', 'Causal Inference', 'Attribution'],
  },
  {
    cat: 'analytics',
    metric: '2.4M LTV predictions/day',
    client: 'CPG',
    title: 'Probabilistic LTV Engine',
    challenge: 'BG/NBD + Gamma-Gamma at population scale, refreshed nightly. Powers segmentation, retention triggers, and lookalike targeting across martech surface area.',
    tags: ['Probabilistic Modeling', 'Big Data', 'Spark'],
  },
  {
    cat: 'analytics',
    metric: '14 unmet demand spaces',
    client: 'CPG',
    title: 'Consumer Occasion Discovery',
    challenge: 'Unsupervised clustering on transaction + diary panel data revealed purchase contexts the brand had no SKUs for. Three NPDs launched against the findings.',
    tags: ['Unsupervised ML', 'Consumer Insights', 'NLP'],
  },
  {
    cat: 'analytics',
    metric: '+22% measured ROI',
    client: 'CPG',
    title: 'Geo-Lift Experimentation Platform',
    challenge: 'Synthetic control + matched-market design at scale. Every campaign now ships with a pre-registered test plan and a measured incremental lift.',
    tags: ['Experimentation', 'Causal Inference', 'A/B Testing'],
  },
  {
    cat: 'analytics',
    metric: '$10M profit / 6 months',
    client: 'CPG',
    title: 'Assortment Optimization at 300K SKU-Stores',
    challenge: 'MIP solver over demand transfer matrices, refreshed weekly. Replaced category-manager intuition with auditable optimization — same shelf, more profit.',
    tags: ['MIP Optimization', 'Big Data', 'Demand Modeling'],
  },
  {
    cat: 'analytics',
    metric: '24h → 2h, 97% on-time',
    client: 'Manufacturing',
    title: 'ML Pricing Engine for Custom Quoting',
    challenge: 'Gradient-boosted price model + feasibility classifier. Replaced 2-day estimator workflow with a 2-hour SLA — and lifted margin 12% on accepted quotes.',
    tags: ['ML', 'Pricing', 'Margin Optimization'],
  },
  {
    cat: 'analytics',
    metric: '14d → real-time',
    client: 'EdTech',
    title: 'Self-Service Analytics Platform',
    challenge: 'Replaced a quarterly-report culture with a streaming warehouse + semantic layer. Execs query in natural language; data team stops being a ticket queue.',
    tags: ['Data Platform', 'Streaming', 'Semantic Layer'],
  },
  {
    cat: 'analytics',
    metric: '+20% conversion',
    client: 'Real Estate',
    title: 'Listing Price ML Model',
    challenge: 'Hedonic regression + gradient boosting on transaction history beat broker pricing intuition in head-to-head A/B. Now the default for new listings.',
    tags: ['ML', 'Forecasting', 'A/B Testing'],
  },
  {
    cat: 'enablement',
    metric: '400+ scientists trained',
    client: 'Energy',
    title: 'Internal Data Science Academy',
    challenge: '32-course curriculum + 6 cohorts + shared MLOps stack. Standardized practice across 4 previously siloed business units; graduates ship to the same platform.',
    tags: ['Enablement', 'Curriculum', 'Platform'],
  },
  {
    cat: 'enablement',
    metric: '$160K/yr saved, weeks → days',
    client: 'Retail',
    title: 'MLOps Platform: L0 → L1',
    challenge: 'Built model registry, automated CI/CD for training pipelines, and cost-aware compute scheduling. 30+ scientists went from "blocked on infra" to shipping weekly.',
    tags: ['MLOps', 'CI/CD', 'Cloud Cost'],
  },
  {
    cat: 'enablement',
    metric: '95% user coverage, day 1',
    client: 'EdTech',
    title: 'Multi-Tenant Recommendation System',
    challenge: 'Hybrid recall (collaborative + content) with strict per-tenant isolation, cold-start handling, and online evaluation. 300K users across 80 tenants on the same stack.',
    tags: ['Recommender Systems', 'Multi-Tenant', 'Online Eval'],
  },
];

const counts = {
  all: cases.length,
  agentic: cases.filter(c => c.cat === 'agentic').length,
  analytics: cases.filter(c => c.cat === 'analytics').length,
  enablement: cases.filter(c => c.cat === 'enablement').length,
};
---

<!-- ============== CASE STUDIES ============== -->
<section class="section cases-section" id="cases">
  <div class="wrap">
    <div class="section-header">
      <div>
        <div class="section-eyebrow">Case Studies</div>
        <h2 class="head section-title">Production systems. 7 industries. Zero pilots stuck in PowerPoint.</h2>
      </div>
      <p class="section-lede">What we ship: working AI systems integrated into your stack — owned, observable, and operated by your team after handoff.</p>
    </div>

    <div class="cases-filterbar">
        <div class="filter-pills" role="tablist" aria-label="Filter case studies">
          <button class="filter-pill active" data-filter="all">All <span class="count">{counts.all}</span></button>
          <button class="filter-pill" data-filter="agentic">Agentic AI <span class="count">{counts.agentic}</span></button>
          <button class="filter-pill" data-filter="analytics">Analytics &amp; ML <span class="count">{counts.analytics}</span></button>
          <button class="filter-pill" data-filter="enablement">Enablement <span class="count">{counts.enablement}</span></button>
        </div>
        <div class="cases-meta">Showing <b id="casesShown">{counts.all}</b> of <b>{counts.all}</b> projects</div>
      </div>

    <div class="cases-grid" id="casesGrid">
        {cases.map((c, i) => (
          <button type="button" class="case" data-cat={c.cat} data-idx={i}>
            <div class="case-metric">{c.metric}</div>
            <span class="case-pill"><span class="dot" aria-hidden="true"></span>{c.client}</span>
            <h3 class="case-title">{c.title}</h3>
            <p class="case-challenge">{c.challenge}</p>
            <div class="case-foot">
              <div class="case-tags">{c.tags.map(t => <span class="case-tag">{t}</span>)}</div>
              <span class="case-arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"/></svg>
              </span>
            </div>
          </button>
        ))}
      </div>
  </div>

  <!-- Modal -->
  <div class="case-modal" id="caseModal" role="dialog" aria-modal="true" aria-labelledby="modalTitle" hidden>
    <div class="case-modal-overlay" data-close=""></div>
    <div class="case-modal-card">
      <button type="button" class="case-modal-close" aria-label="Close" data-close="">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      <span class="modal-pill" id="modalClient"><span class="dot" aria-hidden="true"></span>—</span>
      <div class="modal-metric" id="modalMetric">—</div>
      <h3 class="modal-title" id="modalTitle">—</h3>

      <div class="modal-section">
        <div class="modal-label">Challenge</div>
        <p class="modal-body" id="modalChallenge">—</p>
      </div>

      <div class="modal-section">
        <div class="modal-label">Approach</div>
        <p class="modal-body" id="modalApproach">—</p>
      </div>

      <div class="modal-section">
        <div class="modal-label">Outcomes</div>
        <ul class="modal-results" id="modalResults"></ul>
      </div>

      <div class="modal-tags" id="modalTags"></div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ caseData: cases }}>
  // ====== CASE STUDIES: filter + modal ======
    (function(){
      const grid = document.getElementById('casesGrid');
      if (!grid) return;
      const data = caseData;
      const cards = grid.querySelectorAll('.case');
      const pills = document.querySelectorAll('.filter-pill');
      const shownEl = document.getElementById('casesShown');
  
      // Filter
      let active = 'all';
      pills.forEach(p => {
        p.addEventListener('click', () => {
          active = p.dataset.filter;
          pills.forEach(x => x.classList.toggle('active', x === p));
          let n = 0;
          cards.forEach(c => {
            const show = active === 'all' || c.dataset.cat === active;
            c.hidden = !show;
            if (show) n++;
          });
          if (shownEl) shownEl.textContent = n;
        });
      });
  
      // Modal
      const modal = document.getElementById('caseModal');
      const mClient = document.getElementById('modalClient');
      const mMetric = document.getElementById('modalMetric');
      const mTitle = document.getElementById('modalTitle');
      const mChallenge = document.getElementById('modalChallenge');
      const mApproach = document.getElementById('modalApproach');
      const mResults = document.getElementById('modalResults');
      const mTags = document.getElementById('modalTags');
  
      // Approach + outcome content is synthesized from tags/metric since the
      // source page only provides a challenge teaser. Phrasing stays generic
      // enough to be accurate while concrete enough to read as real work.
      function approachFor(item){
        const t = item.tags.join(' ').toLowerCase();
        if (t.includes('agentic') || t.includes('agent')) {
          return 'Designed and shipped an agent-based system that orchestrates LLMs, tools, and your existing data systems. Evaluations and guardrails enforce quality before each release; observability flags drift in production.';
        }
        if (t.includes('mlops') || t.includes('ci/cd') || t.includes('cloud')) {
          return 'Established the platform foundation: reproducible training pipelines, model registry, automated deployment, and cost-aware infrastructure. Migrated existing workloads incrementally to avoid disruption.';
        }
        if (t.includes('training') || t.includes('enablement')) {
          return 'Built a curriculum grounded in real internal projects, ran cohort-based delivery, and stood up shared tooling and standards so practice continues after the engagement ends.';
        }
        if (t.includes('forecast') || t.includes('optimization')) {
          return 'Built a forecasting and decision layer on top of clean operational data — backtested against historical outcomes, then deployed behind a thin service that fits existing workflows.';
        }
        if (t.includes('recommender')) {
          return 'Designed a multi-tenant recommendation pipeline with strict isolation, per-tenant evaluation, and graceful cold-start handling. Online experiments validated lift before full rollout.';
        }
        return 'Mapped the workflow end-to-end, identified the smallest piece of intelligence that would compound, and shipped it into production behind clear ownership and observability.';
      }
      function outcomesFor(item){
        const out = [item.metric];
        const t = item.tags.join(' ').toLowerCase();
        if (t.includes('agentic') || t.includes('agent')) out.push('Hours of repetitive work removed from the daily loop');
        if (t.includes('ml') || t.includes('forecast')) out.push('Decision quality improved against held-out historical data');
        if (t.includes('optimization') || t.includes('pricing')) out.push('Margin recovered on segments previously priced by intuition');
        if (t.includes('mlops')) out.push('Time-to-deploy reduced from weeks to days');
        if (t.includes('training') || t.includes('enablement')) out.push('Standardized practice across previously siloed teams');
        out.push('Owned and operated by your team after handoff');
        return out.slice(0, 4);
      }
  
      function openModal(idx){
        const item = data[idx];
        mClient.innerHTML = '<span class="dot" aria-hidden="true"></span>' + item.client;
        mMetric.textContent = item.metric;
        mTitle.textContent = item.title;
        mChallenge.textContent = item.challenge.replace(/…$/, '.');
        mApproach.textContent = approachFor(item);
  
        mResults.innerHTML = outcomesFor(item).map(o =>
          '<li>→ ' + o + '</li>'
        ).join('');
  
        mTags.innerHTML = item.tags.map(t => '<span class="case-tag">' + t + '</span>').join('');
  
        modal.hidden = false;
        modal.classList.add('open');
        document.body.style.overflow = 'hidden';
      }
      function closeModal(){
        modal.classList.remove('open');
        modal.hidden = true;
        document.body.style.overflow = '';
      }
      cards.forEach(c => {
        c.addEventListener('click', () => openModal(parseInt(c.dataset.idx, 10)));
      });
      modal.querySelectorAll('[data-close]').forEach(el => {
        el.addEventListener('click', closeModal);
      });
      document.addEventListener('keydown', e => {
        if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
      });
  
      // Pointer-tracked spotlight on cards
      cards.forEach(c => {
        c.addEventListener('pointermove', (e) => {
          const r = c.getBoundingClientRect();
          c.style.setProperty('--mx', ((e.clientX - r.left) / r.width * 100) + '%');
          c.style.setProperty('--my', ((e.clientY - r.top) / r.height * 100) + '%');
        });
      });
    })();
</script>

<style>
  :where(.cases-section, .case-modal) {
    /* === Brand tokens (fallbacks) — your global tokens override these === */
    --bai-navy: var(--navy, #141e42);
    --bai-navy-deep: var(--navy-deep, #0b1230);
    --bai-blue: var(--blue, #195add);
    --bai-purple: var(--purple, #6f5dd2);
    --bai-lavender: var(--lavender, #d2ccf1);
    --bai-line: var(--line, rgba(210, 204, 241, 0.12));
    --bai-line-strong: var(--line-strong, rgba(210, 204, 241, 0.22));
    --bai-muted: var(--muted, rgba(210, 204, 241, 0.72));
    --bai-dim: var(--dim, rgba(210, 204, 241, 0.55));
  }

  /* ---------- CASE STUDIES ---------- */
    .cases-section{
      padding: 120px 0;
      position: relative;
    }
    .cases-section .wrap{
      max-width: 1240px;
      margin: 0 auto;
      padding: 0 32px;
    }
    .cases-section::before{
      content: "";
      position: absolute;
      top: 10%; left: 50%;
      transform: translateX(-50%);
      width: 900px; height: 600px;
      background: radial-gradient(ellipse at center, rgba(25,90,221,0.12), transparent 70%);
      filter: blur(60px);
      pointer-events: none;
    }
    .cases-filterbar{
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      margin: 0 0 36px;
      flex-wrap: wrap;
    }
    .filter-pills{
      display: inline-flex;
      align-items: center;
      padding: 6px;
      border-radius: 999px;
      background: rgba(210, 204, 241, 0.04);
      border: 1px solid var(--bai-line);
      gap: 4px;
      flex-wrap: wrap;
    }
    .filter-pill{
      appearance: none;
      border: none;
      background: transparent;
      color: var(--bai-muted);
      font-family: 'Manrope', sans-serif;
      font-weight: 500;
      font-size: 13px;
      padding: 9px 16px;
      border-radius: 999px;
      cursor: pointer;
      transition: color 0.2s ease, background 0.2s ease;
      white-space: nowrap;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .filter-pill .count{
      font-size: 11px;
      color: var(--bai-dim);
      font-variant-numeric: tabular-nums;
    }
    .filter-pill:hover{ color: white; }
    .filter-pill.active{
      background: linear-gradient(135deg, var(--bai-blue), var(--bai-purple));
      color: white;
      box-shadow: 0 1px 0 rgba(255,255,255,0.18) inset, 0 6px 16px -6px rgba(25,90,221,0.6);
    }
    .filter-pill.active .count{ color: rgba(255,255,255,0.7); }
    .cases-meta{
      font-size: 12.5px;
      color: var(--bai-dim);
      letter-spacing: 0.04em;
    }
    .cases-meta b{
      color: var(--bai-lavender);
      font-weight: 500;
      font-family: 'Inter Tight', sans-serif;
    }
  
    .cases-grid{
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
    }
    @media (max-width: 980px){
      .cases-grid{ grid-template-columns: 1fr; }
    }
    @media (min-width: 981px) and (max-width: 1180px){
      .cases-grid{ grid-template-columns: repeat(2, 1fr); }
    }
  
    .case{
      position: relative;
      background: linear-gradient(180deg, rgba(20, 30, 66, 0.95), rgba(11, 18, 48, 0.95));
      border: 1px solid var(--bai-line);
      border-radius: 18px;
      padding: 32px 28px 26px;
      cursor: pointer;
      overflow: hidden;
      text-align: left;
      width: 100%;
      font-family: inherit;
      color: inherit;
      display: flex;
      flex-direction: column;
      gap: 18px;
      min-height: 290px;
      transition: transform 0.28s cubic-bezier(.2,.7,.2,1), border-color 0.28s ease, box-shadow 0.28s ease, background 0.28s ease;
    }
    .case::before{
      content: "";
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent 0%, var(--bai-blue) 30%, var(--bai-purple) 70%, transparent 100%);
      opacity: 0.55;
      transition: opacity 0.28s ease, height 0.28s ease;
    }
    .case::after{
      content: "";
      position: absolute;
      inset: -1px;
      border-radius: 18px;
      pointer-events: none;
      background: radial-gradient(600px circle at var(--mx, 50%) var(--my, -20%), rgba(25,90,221,0.18), transparent 40%);
      opacity: 0;
      transition: opacity 0.28s ease;
    }
    .case:hover{
      transform: translateY(-4px);
      border-color: rgba(25, 90, 221, 0.5);
      box-shadow: 0 24px 48px -20px rgba(25, 90, 221, 0.35), 0 0 0 1px rgba(25, 90, 221, 0.25);
      background: linear-gradient(180deg, rgba(25, 36, 80, 0.95), rgba(13, 20, 56, 0.95));
    }
    .case:hover::before{ opacity: 1; height: 2px; }
    .case:hover::after{ opacity: 1; }
    .case:hover .case-arrow{
      background: var(--bai-blue);
      border-color: var(--bai-blue);
      color: white;
      transform: translate(2px, -2px);
    }
  
    .case-metric{
      font-family: 'Inter Tight', sans-serif;
      font-weight: 500;
      letter-spacing: -0.02em;
      line-height: 1.05;
      font-size: 28px;
      background: linear-gradient(120deg, var(--bai-blue) 0%, var(--bai-purple) 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      padding-right: 40px;
    }
    .case-pill{
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 10px;
      border-radius: 999px;
      background: rgba(210, 204, 241, 0.06);
      border: 1px solid var(--bai-line);
      font-size: 10.5px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 600;
      color: var(--bai-lavender);
      width: fit-content;
      margin-top: -4px;
    }
    .case-pill .dot{
      width: 4px; height: 4px; border-radius: 50%;
      background: var(--bai-blue);
    }
    .case-title{
      font-family: 'Inter Tight', sans-serif;
      font-weight: 500;
      font-size: 19px;
      color: white;
      margin: 0;
      letter-spacing: -0.01em;
      line-height: 1.3;
    }
    .case-challenge{
      font-size: 13.5px;
      color: var(--bai-muted);
      line-height: 1.55;
      margin: 0;
      flex: 1;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .case-foot{
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-top: auto;
      padding-top: 16px;
      border-top: 1px solid var(--bai-line);
    }
    .case-tags{
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }
    .case-tag{
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.01em;
      color: #a8b8ff;
      background: rgba(25, 90, 221, 0.12);
      border: 1px solid rgba(25, 90, 221, 0.28);
      padding: 4px 9px;
      border-radius: 6px;
      white-space: nowrap;
    }
    .case-arrow{
      width: 30px; height: 30px;
      border-radius: 50%;
      border: 1px solid var(--bai-line-strong);
      color: var(--bai-lavender);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: all 0.28s ease;
      flex-shrink: 0;
    }
    .case-arrow svg{ width: 12px; height: 12px; }
  
    /* hidden state for filtering */
    .case[hidden]{ display: none; }
  
    /* ---------- CASE MODAL ---------- */
    .case-modal{
      position: fixed;
      inset: 0;
      z-index: 100;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 32px;
    }
    .case-modal.open{ display: flex; }
    .case-modal-overlay{
      position: absolute;
      inset: 0;
      background: rgba(7, 11, 28, 0.78);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      animation: fade-in 0.25s ease both;
    }
    .case-modal-card{
      position: relative;
      width: min(820px, 100%);
      max-height: calc(100vh - 64px);
      overflow-y: auto;
      background:
        radial-gradient(ellipse at 0% 0%, rgba(25, 90, 221, 0.18), transparent 50%),
