---
// CaseStudies.astro
// Drop into src/components/ and use as <CaseStudies /> in any Astro page.
//
// Brand tokens used: --blue (#195add), --purple (#6f5dd2), --navy (#141e42),
// --lavender (#d2ccf1). These are read with fallbacks, so the section works
// standalone OR picks up your global tokens if you define them.
//
// The case-study data is inlined below in TypeScript. Edit the array to add /
// remove projects. The "cat" field controls the filter bucket (agentic | analytics
// | enablement); add new categories by also editing the filter pill markup.
//
// Fonts assumed: Manrope (body) + Inter Tight (headings) loaded globally by your
// site. If you don't load them, the snippet falls back to system sans-serif.

interface CaseStudy {
  cat: 'agentic' | 'analytics' | 'enablement';
  metric: string;
  client: string;
  title: string;
  challenge: string;
  tags: string[];
}

const cases: CaseStudy[] = [
  {
    "cat": "agentic",
    "metric": "Millions of users served",
    "client": "Infobase · EdTech",
    "title": "Intelligent Content Orchestration",
    "challenge": "Content discovery was manual, curation slow, support workflows required constant human intervention.",
    "tags": [
      "Agentic AI",
      "Content Automation"
    ]
  },
  {
    "cat": "agentic",
    "metric": "Clinician prep time slashed",
    "client": "PhysioAge · Healthcare",
    "title": "Pre-Consultation Patient Intelligence",
    "challenge": "Clinicians spent hours manually reviewing complex patient histories scattered across systems.",
    "tags": [
      "Agentic AI",
      "Clinical Support"
    ]
  },
  {
    "cat": "agentic",
    "metric": "Proactive care enabled",
    "client": "PhysioAge · Healthcare",
    "title": "Predictive Intervention Alerts",
    "challenge": "High-risk patients identified reactively — after escalation — rather than proactively.",
    "tags": [
      "ML",
      "Agentic AI",
      "Real-Time"
    ]
  },
  {
    "cat": "agentic",
    "metric": "Treatment consistency enhanced",
    "client": "PhysioAge · Healthcare",
    "title": "Treatment Recommendation Engine",
    "challenge": "Variability across clinicians reduced consistency. Scaling personalized protocols required vast synthesis.",
    "tags": [
      "Agentic AI",
      "Explainable AI"
    ]
  },
  {
    "cat": "agentic",
    "metric": "25% engagement increase",
    "client": "Leading AI Consultancy · Technology",
    "title": "Enterprise Sales Agent",
    "challenge": "Sales team needed real-time intelligence on public companies. Manual research: hours per prospect, inconsistent quality.",
    "tags": [
      "Agentic AI",
      "GenAI",
      "Finance"
    ]
  },
  {
    "cat": "agentic",
    "metric": "20% revenue increase",
    "client": "Logistics Company · Transportation",
    "title": "Route Optimization Intelligence",
    "challenge": "Rising costs, static routing, manual dispatch eroding margins. No real-time response capability.",
    "tags": [
      "AI Agents",
      "Optimization",
      "Big Data"
    ]
  },
  {
    "cat": "analytics",
    "metric": "Clear revenue attribution",
    "client": "Keurig Dr Pepper · CPG / Beverages",
    "title": "Sales Decomposition & Attribution",
    "challenge": "Needed to isolate true sales drivers — media, distribution, pricing, seasonality — to replace intuition.",
    "tags": [
      "Statistical Modeling",
      "Attribution"
    ]
  },
  {
    "cat": "analytics",
    "metric": "Millions of LTV predictions",
    "client": "Keurig Dr Pepper · CPG / Beverages",
    "title": "Customer LTV Pipeline at Scale",
    "challenge": "No scalable system for customer-level LTV. Existing approaches too simplistic for precision targeting.",
    "tags": [
      "ML",
      "Probabilistic Modeling"
    ]
  },
  {
    "cat": "analytics",
    "metric": "Unmet demand identified",
    "client": "Keurig Dr Pepper · CPG / Beverages",
    "title": "Demand Spaces Analysis",
    "challenge": "Product-centric category management. Needed occasion-based demand understanding for innovation.",
    "tags": [
      "ML",
      "Consumer Insights"
    ]
  },
  {
    "cat": "analytics",
    "metric": "ROI measurably improved",
    "client": "Keurig Dr Pepper · CPG / Beverages",
    "title": "Precision Marketing & Distribution",
    "challenge": "Broad-segment marketing. No measurement of incremental impact, impossible to optimize ROI.",
    "tags": [
      "Experimentation",
      "Optimization"
    ]
  },
  {
    "cat": "analytics",
    "metric": "$10M profit lift in 6 months",
    "client": "AB InBev · CPG / Beverages",
    "title": "Assortment Optimization at Scale",
    "challenge": "Assortment decisions across 300K stores driven by tradition. Sub-optimal SKUs costing millions.",
    "tags": [
      "Optimization",
      "Big Data"
    ]
  },
  {
    "cat": "analytics",
    "metric": "97% on-time quotes",
    "client": "Top U.S. Manufacturer · Manufacturing",
    "title": "Pricing Optimization Engine",
    "challenge": "24-hour quote turnaround, inconsistent pricing, lost deals. Needed real-time ML-driven pricing.",
    "tags": [
      "ML",
      "Pricing",
      "Automation"
    ]
  },
  {
    "cat": "analytics",
    "metric": "Real-time visibility achieved",
    "client": "Infobase · EdTech",
    "title": "Executive Analytics Dashboards",
    "challenge": "No real-time visibility into content usage or product performance. Decisions based on delayed reports.",
    "tags": [
